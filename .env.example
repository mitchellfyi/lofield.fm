# Supabase Configuration
# Get these from your Supabase project settings (https://supabase.com/dashboard/project/_/settings/api)

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase publishable default key (public, safe for client-side)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-default-key-here

# Supabase service role key (server-side only, NEVER expose to client)
# Required for admin operations, Vault access, and Storage management
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Development Fallback API Keys
# These are only used as fallbacks during development if users haven't saved their own keys via Vault
# In production, users should provide their own keys through the app settings

# OpenAI API key (optional fallback for development)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ElevenLabs API key (optional fallback for development)
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-key-here
