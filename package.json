{
  "name": "lofield-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.18.0",
    "pnpm": "10.26.x"
  },
  "scripts": {
    "dev": "pnpm db:ensure && next dev --port 3003",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "echo \"No e2e tests configured yet\" && exit 0",
    "db:ensure": "node scripts/ensure-db.js",
    "db:migrate": "supabase db push --db-url \"$SUPABASE_DB_URL\"",
    "docs:check": "tsx scripts/docs-check.ts",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm docs:check"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.86",
    "@ai-sdk/react": "^2.0.115",
    "@elevenlabs/elevenlabs-js": "^2.27.0",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.1",
    "ai": "^5.0.52",
    "dotenv": "^16.4.5",
    "next": "16.0.10",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.26.0+sha512.3b3f6c725ebe712506c0ab1ad4133cf86b1f4b687effce62a9b38b4d72e3954242e643190fc51fa1642949c735f403debd44f5cb0edd657abe63a8b6a7e1e402"
}
